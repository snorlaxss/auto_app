<?xml version="1.0"?>
<robot name="marvin_robot" xmlns:xacro="http://ros.org/wiki/xacro">
 <xacro:macro  name="mobile_base">
  <!-- Define mesh path as a Xacro property -->
  <!-- base Link -->

  <!-- ================= Mobile Base ================= -->
<link name="mobile_base_link">
  <inertial>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <mass value="15.0"/>
    <inertia
      ixx="0.5" ixy="0" ixz="0"
      iyy="0.6" iyz="0"
      izz="0.7"/>
  </inertial>

  <visual>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <geometry>
      <!-- 移动底盘 box -->
      <box size="0.6 0.4 0.2"/>
    </geometry>
    <material name="gray">
      <color rgba="0.6 0.6 0.6 1"/>
    </material>
  </visual>

  <collision>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <geometry>
      <box size="0.6 0.4 0.2"/>
    </geometry>
  </collision>
</link>

  <!-- <joint name="mb_link" type="fixed">
    <parent link="mobile_base_link"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
  </joint>   -->


<link name="lift_link">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.8"/>
    <inertia
      ixx="5e-4" ixy="0" ixz="0"
      iyy="5e-4" iyz="0"
      izz="5e-4"/>
  </inertial>

  <!-- 可视化：立柱（可选） -->
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.15 0.15 0.5"/>
    </geometry>
    <material name="dark_gray">
      <color rgba="0.4 0.4 0.4 1.0"/>
    </material>
  </visual>

  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.15 0.15 0.5"/>
    </geometry>
  </collision>
</link>

<joint name="base_lift_joint" type="prismatic">
  <parent link="mobile_base_link"/>
  <child link="lift_link"/>

  <!-- 升降起点 -->
  <origin xyz="-0.2 0 0.5" rpy="0 0 0"/>

  <!-- 沿 Z 轴升降 -->
  <axis xyz="0 0 1"/>

  <!-- 行程 -->
  <limit lower="0.0" upper="0.4" effort="300" velocity="0.2"/>
</joint>

<link name="pitch_link">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.5"/>
    <inertia
      ixx="1e-4" ixy="0" ixz="0"
      iyy="1e-4" iyz="0"
      izz="1e-4"/>
  </inertial>

  <!-- 可视化：球 -->
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.10"/>
    </geometry>
    <material name="blue">
      <color rgba="0.2 0.4 0.9 1.0"/>
    </material>
  </visual>

  <!-- 碰撞：球 -->
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.10"/>
    </geometry>
  </collision>
</link>


<joint name="lift_pitch_joint" type="revolute">
  <parent link="lift_link"/>
  <child link="pitch_link"/>
  <origin xyz="0.3 0 0.0" rpy="0 0 0"/>
  <axis xyz="0 1 0"/>
  <limit lower="-0.1" upper="1.0" effort="50" velocity="2.0"/>
</joint>
<joint name="base_yaw_joint" type="revolute">
  <parent link="pitch_link"/>
  <child link="base_link"/>
  <origin xyz="0 0 0.2" rpy="0 0 0"/>
  <axis xyz="0 0 1"/>
  <limit lower="-0.5" upper="0.5" effort="50" velocity="2.0"/>
</joint>


  <link
      name="base_link">
      <inertial>
        <origin
          xyz="6.8101E-06 5.7901E-11 0.068902"
          rpy="0 0 0" />
        <mass
          value="1.21" />
        <inertia
          ixx="0.00393"
          ixy="1.5099E-09"
          ixz="-3.4422E-07"
          iyy="0.0047631"
          iyz="8.9145E-13"
          izz="0.0034321" />
      </inertial>
      <visual>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://marvin_description/meshes/base/base_link.STL" />
        </geometry>
        <material
          name="">
          <color
            rgba="0.75294 0.75294 0.75294 1" />
        </material>
      </visual>
      <collision>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://marvin_description/meshes/base/base_link.STL" />
        </geometry>
      </collision>
    </link>
  
  <link name="tracking_base_link"/>
  <joint name="base_to_tracking_base" type="fixed">
    <parent link="mobile_base_link"/>
    <child link="tracking_base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  
  <link name="camera_link"/>
    <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin rpy="-2.39 0.0 -1.57" xyz="0.022 0.07 0.48"/>
  </joint>
  
</xacro:macro>
</robot>

